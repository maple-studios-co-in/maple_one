# Feature-flag console (Flipt) — protected by basic auth.
# Set FLAGS_PASSWORD_HASH in .env (user is "maple"). Rotate with:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'NEWPASS'
flags.maplefurnishers.com {
	basic_auth {
		maple {env.FLAGS_PASSWORD_HASH}
	}
	reverse_proxy flipt:8080
}
