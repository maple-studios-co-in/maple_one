# Copy to .env (compose reads it). Do NOT commit the real .env.
DATABASE_URL="postgresql://postgres:maple@postgres:5432/mapletools?schema=public"
POSTGRES_PASSWORD="change-me-strong"
AUTH_SECRET="openssl rand -hex 32"
COOKIE_DOMAIN=".maplefurnishers.com"
SSO_DOMAIN=".maplefurnishers.com"
LOGIN_URL="https://admin.maplefurnishers.com/login"
NEXT_PUBLIC_SUITE_DOMAIN=".maplefurnishers.com"
CATALOG_STORAGE="/data/catalog"
ADMIN_EMAIL="admin@maplefurnishers.com"
ADMIN_PASSWORD="change-me"

# Feature flags (Flipt runs as a compose service). Unset => fail-open (all enabled).
FLIPT_URL="http://flipt:8080"
FLIPT_NAMESPACE="default"

# Basic-auth hash that protects the public Flipt console (flags.maplefurnishers.com).
# Caddy reads this; the login user is "maple". The default below is the bcrypt hash
# of "maple-flags-change-me" — CHANGE IT before going live:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'NEWPASS'
# (env_file values are literal — keep the $ characters exactly, do not quote.)
FLAGS_PASSWORD_HASH=$2b$14$Al3NBKzzZ/4vcbyvzsOsI.xwhnKal4Q0QMfDU66M4CKiWLhPMRW.C
