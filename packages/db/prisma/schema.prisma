// MapleTools — shared data model (self-hosted Postgres). One DB powers the whole
// *.mf.com tool family; each tool app reads the models it needs.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id               String            @id @default(cuid())
  name             String
  company          String?
  type             String            @default("b2c") // b2b | b2c
  gstin            String?
  phone            String?
  email            String?
  address          String?
  status           String            @default("active") // lead | active | dormant
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  leads            Lead[]
  invoices         Invoice[]
  quotations       Quotation[]
  orders           Order[]
  payments         Payment[]
  deliveryChallans DeliveryChallan[]
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  source    String?
  status    String   @default("new") // new | contacted | quoted | won | lost
  note      String?
  value     Float?
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Quotation {
  id        String   @id @default(cuid())
  number    String   @unique
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  data      Json
  total     Float    @default(0)
  status    String   @default("draft")
  createdAt DateTime @default(now())
  orders    Order[]
}

model Invoice {
  id        String    @id @default(cuid())
  number    String    @unique
  clientId  String?
  client    Client?   @relation(fields: [clientId], references: [id])
  data      Json
  total     Float     @default(0)
  status    String    @default("unpaid") // unpaid | partial | paid
  dueDate   DateTime?
  createdAt DateTime  @default(now())
  payments  Payment[]
}

model Payment {
  id        String    @id @default(cuid())
  invoiceId String?
  invoice   Invoice?  @relation(fields: [invoiceId], references: [id])
  clientId  String?
  client    Client?   @relation(fields: [clientId], references: [id])
  label     String? // Advance | Woodwork | Balance | …
  amount    Float
  method    String? // upi | bank | cash | cheque
  dueDate   DateTime?
  paidAt    DateTime?
  status    String    @default("due") // due | paid
  note      String?
  createdAt DateTime  @default(now())
}

model Order {
  id           String     @id @default(cuid())
  code         String     @unique
  title        String
  clientId     String?
  client       Client?    @relation(fields: [clientId], references: [id])
  quotationId  String?
  quotation    Quotation? @relation(fields: [quotationId], references: [id])
  stage        String     @default("accepted") // accepted | production | delivery | installed
  value        Float      @default(0)
  deliveryDate DateTime?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model InventoryItem {
  id           String   @id @default(cuid())
  name         String
  category     String? // timber | fabric | hardware | finished | other
  sku          String?
  unit         String   @default("nos") // nos | sqft | rft | mtr | set
  quantity     Float    @default(0)
  reorderLevel Float    @default(0)
  cost         Float?
  location     String?
  updatedAt    DateTime @updatedAt
}

model FinanceEntry {
  id        String   @id @default(cuid())
  type      String // income | expense
  category  String?
  amount    Float
  note      String?
  date      DateTime @default(now())
  invoiceId String?
}

model HrDocument {
  id           String   @id @default(cuid())
  type         String
  employeeName String
  data         Json
  createdAt    DateTime @default(now())
}

// Catalog / price-list — also the source for quotation templates.
model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String?
  category    String?
  material    String?
  description String?
  unit        String   @default("nos")
  price       Float? // selling rate
  cost        Float? // landed cost
  imageUrl    String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Collection {
  id          String   @id @default(cuid())
  title       String
  theme       String?
  slug        String   @unique
  shareToken  String   @unique
  description String?
  spaces      String[] @default([])
  categories  String[] @default([])
  pageCount   Int      @default(0)
  hasPdf      Boolean  @default(false)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Shoot {
  id         String   @id @default(cuid())
  title      String
  product    String?
  colorway   String?
  style      String?
  status     String   @default("draft") // draft | ready
  hasSource  Boolean  @default(false)
  hasVideo   Boolean  @default(false)
  shareToken String   @unique
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  number       String    @unique
  vendor       String
  items        String?
  total        Float     @default(0)
  status       String    @default("draft") // draft | sent | received
  expectedDate DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model DeliveryChallan {
  id        String   @id @default(cuid())
  number    String   @unique
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  items     String?
  vehicleNo String?
  driver    String?
  status    String   @default("prepared") // prepared | dispatched | delivered
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id        String   @id @default(cuid())
  category  String? // materials | labour | transport | rent | utilities | misc
  vendor    String?
  amount    Float
  method    String? // cash | upi | bank | card
  note      String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

model Tenant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  domain       String?  @unique
  brandName    String   @default("MapleOne")
  logoUrl      String?
  primaryColor String?
  watermarkEnabled Boolean @default(false)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  permissions String[] @default([])
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo")     // todo | in_progress | blocked | done
  priority    String    @default("medium")   // low | medium | high
  assigneeId  String?
  assignee    User?     @relation(fields: [assigneeId], references: [id])
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Doc {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  tagline   String?
  body      String   @default("")
  updatedAt DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("sales") // admin | sales | accounts | hr
  active       Boolean  @default(true)
  tasks        Task[]
  createdAt    DateTime @default(now())
}
